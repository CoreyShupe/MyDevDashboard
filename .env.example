# Copy to `.env` and adjust as needed. `.env` is git-ignored.
# These values are consumed by BOTH docker-compose (the DB container) and the app.

POSTGRES_USER=devdash
POSTGRES_PASSWORD=devdash
POSTGRES_DB=devdash
# Host port mapped to the container's 5432. 5433 avoids clashing with a system postgres.
POSTGRES_PORT=5433

# Connection string the application uses. Must match the values above.
# sslmode=disable because this is a local docker instance.
DATABASE_URL=postgres://devdash:devdash@localhost:5433/devdash?sslmode=disable

# Optional: log filter (see tracing-subscriber EnvFilter syntax).
RUST_LOG=my_dev_dashboard=info,warn
