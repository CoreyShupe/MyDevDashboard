#!/usr/bin/env bash
#
# dev-dash — top-level CLI for the Dev Dashboard.
#
# Symlink it into your system bin, e.g.:
#     ln -s "$(pwd)/dev-dash" /usr/local/bin/dev-dash   # or ~/bin/dev-dash
#
# Commands:
#     dev-dash build [release]  Compile (debug by default; `release` for optimized).
#     dev-dash db up            Start the local PostgreSQL (persistent volume).
#     dev-dash db down          Stop it (data preserved).
#     dev-dash db reset         DESTROY the volume + all data (confirmation-gated).
#     dev-dash db psql          Open a psql shell against the running DB.
#     dev-dash sandbox CMD      Isolated SANDBOX db for migration checks — never touches prod.
#                               CMD = up|down|reset|psql|migrate|url (port 5434). See AGENTS §12.
#     dev-dash open [prod]      Launch the app DETACHED and exit 0.
#                               default = dev (`cargo run`, debug);
#                               `prod`  = release build, then run the binary.
#                               In-app "Restart" (exit 86) is caught here: dev re-runs
#                               `cargo run`; prod rebuilds + relaunches. The Restart button
#                               only exists in dev/debug builds — release omits it.
#     dev-dash bundle [copy]    Build a macOS .app bundle into builds/macos/DevDashboard.app.
#                               Release-builds, then assembles a bundle whose executable is a
#                               SYMLINK to target/release/<bin> (not a copy) and whose launcher
#                               cd's into the bundle to load a COPIED .env. Double-clickable.
#                               `copy` also installs it into /Applications (so Spotlight/Launchpad
#                               find it).
#     dev-dash shot VIEW OUT    Screenshot a DEV_VIEW to OUT.png, then exit the app.
#                               VIEW = onboarding|new-profile|board|ticket|page|create|
#                                      notes|notes-file|error (see ui::dev).
#                               Encapsulates the whole build->launch->capture->kill flow
#                               (captures the mock window by id+title) so only this one
#                               script needs to be trusted.
#     dev-dash snap [OUT]       Screenshot the ALREADY-RUNNING app to OUT (default
#                               static/tmp/screenshots/live.png). Does NOT build, launch, or close it
#                               — use it to see the live app with the owner's real data.
set -euo pipefail

# Resolve this script's real directory, following symlinks so it works when symlinked
# into a system bin. (Uses the requested `cd … dirname BASH_SOURCE … pwd` pattern, made
# symlink-safe.)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR=$( cd -- "$( dirname -- "$SOURCE" )" &> /dev/null && pwd )
  SOURCE=$( readlink "$SOURCE" )
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR=$( cd -- "$( dirname -- "$SOURCE" )" &> /dev/null && pwd )
cd "$SCRIPT_DIR"

usage() {
  # Print the command reference from this file's header comment.
  sed -n '3,35p' "$SOURCE"
  exit "${1:-0}"
}

# Capture ONLY the app window to OUT — never the macOS menu bar (top) or dock (bottom), which
# can leak other apps / notifications (opsec). `static/scripts/window-id.swift` looks up the app's
# on-screen window id via CoreGraphics; we hand it to `screencapture -l` so only that window's
# pixels are grabbed. Because `-l <id>` grabs the window's OWN image, it works even when the
# window is occluded or not frontmost — so there's no need to raise it first (which is why this
# whole path needs only Screen Recording, never Accessibility). `-o` drops the drop shadow for
# clean edges. The 2nd arg (`dev`|`live`) picks WHICH window by title: a DEV_VIEW mock is titled
# "Dev Dashboard [DEV: …]", the live app plain "Dev Dashboard", so `shot` (dev) and `snap` (live)
# can never grab each other's window even when both are on screen. Falls back to a full-screen
# grab (with a warning) if the window can't be found, so a capture never silently produces nothing.
capture_window() {
  local out="$1"
  local mode="${2:-live}"
  local winid
  winid=$(/usr/bin/swift "$SCRIPT_DIR/static/scripts/window-id.swift" "$mode" 2>/dev/null || true)
  if [[ "$winid" =~ ^[0-9]+$ ]]; then
    screencapture -x -o -l"$winid" "$out"
  else
    echo "dev-dash: warning: couldn't find the app window; capturing full screen" >&2
    screencapture -x "$out"
  fi
}

cmd="${1:-open}"
case "$cmd" in
  build)
    case "${2:-}" in
      ""|debug) exec cargo build ;;
      release)  exec cargo build --release ;;
      *)        echo "error: unknown build mode '${2:-}' (use 'release' or omit)" >&2; usage 1 ;;
    esac
    ;;

  db)
    case "${2:-}" in
      up)    exec ./static/scripts/db-up.sh ;;
      down)  exec ./static/scripts/db-down.sh ;;
      reset) exec ./static/scripts/db-reset.sh ;;
      psql)  exec ./static/scripts/db-psql.sh ;;
      *)     echo "error: unknown 'db' subcommand '${2:-}'" >&2; usage 1 ;;
    esac
    ;;

  sandbox)
    # Isolated sandbox DB for verifying migrations (AGENTS.md §12) — fully separate from the
    # production `db` stack. Forwards the subcommand (up|down|reset|psql|migrate|url).
    shift
    exec ./static/scripts/sandbox-db.sh "$@"
    ;;

  open)
    mode="${2:-dev}"
    # The in-app "Restart" button exits with this code; the detached loops below catch it and
    # relaunch instead of stopping. MUST match RESTART_EXIT_CODE in src/main.rs.
    restart_code=86
    case "$mode" in
      dev)
        echo "dev-dash: launching (dev, cargo run; Restart re-runs) …"
        # Loop: re-run on the restart code, stop on any other exit (incl. a normal close).
        nohup bash -c '
          restart=$1
          while true; do
            cargo run
            [ $? -eq "$restart" ] || break
          done
        ' _ "$restart_code" >/dev/null 2>&1 &
        ;;
      prod)
        echo "dev-dash: building release …"
        cargo build --release
        bin=$(grep -m1 '^name' Cargo.toml | sed -E 's/.*"([^"]+)".*/\1/')
        echo "dev-dash: launching (prod; Restart rebuilds) …"
        # Loop: run the binary; on the restart code rebuild and run again, else stop.
        nohup bash -c '
          restart=$1; bin=$2
          while true; do
            "./target/release/$bin"
            [ $? -eq "$restart" ] || break
            cargo build --release || break
          done
        ' _ "$restart_code" "$bin" >/dev/null 2>&1 &
        ;;
      *)
        echo "error: unknown open mode '$mode' (omit for dev, or 'prod')" >&2
        usage 1
        ;;
    esac
    disown || true
    exit 0
    ;;

  bundle)
    # Assemble a macOS .app bundle (release build + symlinked binary + copied .env).
    #   (no arg) → build into builds/macos/  ·  copy → build, then install into /Applications.
    case "${2:-}" in
      "")   exec ./static/scripts/bundle-macos.sh ;;
      copy) exec ./static/scripts/bundle-macos.sh copy ;;
      *)    echo "error: unknown 'bundle' subcommand '${2:-}' (use 'copy' or omit)" >&2; usage 1 ;;
    esac
    ;;

  shot)
    view="${2:-}"
    out="${3:-}"
    if [[ -z "$view" || -z "$out" ]]; then
      echo "error: usage: dev-dash shot VIEW OUT.png" >&2
      usage 1
    fi
    cargo build
    bin="$SCRIPT_DIR/target/debug/$(grep -m1 '^name' Cargo.toml | sed -E 's/.*"([^"]+)".*/\1/')"
    pkill -f "$bin" 2>/dev/null || true
    DEV_VIEW="$view" RUST_LOG=warn "$bin" >/dev/null 2>&1 &
    # Wait for the window to appear, then capture it BY ID (screencapture -l grabs the window's
    # own image even when it isn't frontmost/occluded — no raise needed). Match the DEV window by
    # title (mode "dev") so a running live app is never captured into a mock shot.
    perl -e 'select(undef,undef,undef,4)'
    capture_window "$out" "dev"
    pkill -f "$bin" 2>/dev/null || true
    echo "dev-dash: captured $view -> $out"
    exit 0
    ;;

  snap)
    # Screenshot the ALREADY-RUNNING app — no build, no launch, no kill. For "look at my app
    # and tell me what you see" against the owner's real, live data.
    out="${2:-static/tmp/screenshots/live.png}"
    bin_name=$(grep -m1 '^name' Cargo.toml | sed -E 's/.*"([^"]+)".*/\1/')
    if ! pgrep -f "$bin_name" >/dev/null 2>&1; then
      echo "error: the app isn't running. Launch it with 'dev-dash open' first." >&2
      exit 1
    fi
    mkdir -p "$(dirname "$out")"
    # Capture the LIVE window by id (title-matched "live"); screencapture -l grabs it even when
    # it's behind other windows, so no raise (and no Accessibility) is needed.
    capture_window "$out" "live"
    echo "dev-dash: captured live app -> $out"
    exit 0
    ;;

  ""|-h|--help|help)
    usage 0
    ;;

  *)
    echo "error: unknown command '$cmd'" >&2
    usage 1
    ;;
esac
